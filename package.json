    "copy:env": "node ./scripts/copy-env.js",
    "typecheck": "node ./node_modules/typescript/lib/tsc.js --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsconfig.tsbuildinfo --pretty",
