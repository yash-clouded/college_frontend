# FastAPI base URL for production builds (omit in dev — Vite proxies /api to the backend).
# Use origin only, e.g. https://api.yourdomain.com (not .../api).
# VITE_REST_API_URL=https://api.yourdomain.com

# Firebase web app (College Connects) - Replace these with your own keys
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT_ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT_ID.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Razorpay Checkout (public key_id only — never put key_secret in the frontend)
VITE_RAZORPAY_KEY=YOUR_RAZORPAY_KEY_ID

# ------------------------------------------------------------
# Backend service variables (keep real values only in local/private env files)
# ------------------------------------------------------------
MONGODB_URI=YOUR_MONGODB_URI
DATABASE_NAME=collegeconnect

FIREBASE_SERVICE_ACCOUNT_PATH=firebase-adminsdk.json

# Resend — session booking emails to advisors
RESEND_API_KEY=YOUR_RESEND_API_KEY
# Must use an address on your verified domain
RESEND_FROM=CollegeConnect <bookings@yourdomain.com>

# AWS S3
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
S3_BUCKET=YOUR_S3_BUCKET

# Razorpay server-side keys
RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

